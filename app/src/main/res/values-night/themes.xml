<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FitLife" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryVariant">@color/accent_orange</item>
        <item name="colorOnPrimary">@color/primary_black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/primary_black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/main_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <!-- Background color -->
        <item name="android:windowBackground">@color/main_background</item>
        <item name="backgroundColor">@color/main_background</item>
    </style>
</resources>
